# Supabase (required — copy from Bolt database settings or supabase.com > Project Settings > API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# The following are Edge Function secrets — set them in Supabase > Edge Functions > Secrets,
# NOT in Netlify environment variables.

# Stripe (required for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (required for email notifications)
RESEND_API_KEY=
